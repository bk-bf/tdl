# .tdlignore — hide these from the tdl file tree and file finder
# Used by nvim-tree (filters.custom) and Telescope (file_ignore_patterns).
# Patterns are matched against the full path, so bare names match anywhere.
# One pattern per line. Lines starting with # are comments.

# ── Bare git repo internals ──────────────────────────────────────────────────
# These live at the bare repo root (tdl/) and are git's plumbing — never edit.
hooks
info
logs
objects
refs
worktrees
packed-refs
config
description
HEAD

#!/usr/bin/env bash
# aid-sessions — orchestrator session navigator (T-ORC-5: enhanced fzf TUI).
#
# Displays all aid@<project>/<slug> tmux sessions in a rich fzf interface:
#   - Project group headers with collapse/expand  (z)
#   - Branch names and activity status from metadata
#   - Preview pane: repo path, branch, git status, timestamps
#   - Dead session resurrection                   (Enter on dead session)
#   - Rename session                              (r)
#   - Delete session with cleanup                 (d)
#   - New session                                 (n)
#   - Manual refresh                              (ctrl-r)
#
# Invoked by:
#   - orchestrator.sh when sessions already exist
#   - tmux.conf prefix+s binding: tmux display-popup -E "$AID_DIR/aid-sessions"
#
# Requirements: fzf >= 0.57
#
# TODO(T-ORC-5b): replace with a Go/Bubble Tea TUI for richer UX (proper
#   cursor navigation, collapse animation, mouse support, inline rename).

set -euo pipefail

: "${AID_DIR:?}"
: "${AID_DATA:?}"

# shellcheck source=lib/sessions/aid-meta
source "$AID_DIR/lib/sessions/aid-meta"

# ── Collapse state ────────────────────────────────────────────────────────────
# Tmpfile listing collapsed project names, one per line.
# Exported so aid-sessions-list and aid-sessions-action can read it.
export AID_SESSIONS_COLLAPSE
AID_SESSIONS_COLLAPSE=$(mktemp /tmp/aid-sessions-collapse.XXXXXX)
trap 'rm -f "$AID_SESSIONS_COLLAPSE"' EXIT

# ── Helpers ───────────────────────────────────────────────────────────────────

_switch() {
  local session="$1"
  if [[ -n "${TMUX:-}" ]]; then
    tmux -L aid switch-client -t "$session"
  else
    tmux -L aid attach -t "$session"
  fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v fzf &>/dev/null; then
  echo "aid-sessions: fzf not found — install fzf for the session navigator" >&2
  tmux -L aid list-sessions -F "#{session_name}" 2>/dev/null \
    | grep -E '^aid@[^/]+/[^/]+$' || true
  exit 1
fi

# Pre-build the action and reload command strings (expanded once, safe paths).
_act="AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") AID_SESSIONS_COLLAPSE=$(printf '%q' "$AID_SESSIONS_COLLAPSE") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-action")"
_lst="AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") AID_SESSIONS_COLLAPSE=$(printf '%q' "$AID_SESSIONS_COLLAPSE") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-list")"

_initial_list=$("$AID_DIR/lib/sessions/aid-sessions-list" 2>/dev/null || true)

if [[ -z "$_initial_list" ]]; then
  echo "no orchestrator sessions — run: aid --mode orchestrator"
  exit 0
fi

_selected=$(printf '%s\n' "$_initial_list" | fzf \
  --prompt="  " \
  --border=rounded \
  --border-label=" aid sessions " \
  --border-label-pos=3 \
  --header=$'  \033[2menter\033[0m switch  \033[2mn\033[0m new  \033[2mr\033[0m rename  \033[2md\033[0m delete  \033[2mz\033[0m collapse  \033[2mctrl-r\033[0m refresh  \033[2mq/esc\033[0m quit' \
  --no-sort \
  --ansi \
  --delimiter='\t' \
  --with-nth=1 \
  --accept-nth='2' \
  --preview="$_act preview {}" \
  --preview-window='right:42%:wrap:border-left' \
  --preview-label=' info ' \
  --color='border:238,label:blue,preview-border:238,preview-label:blue,header:italic:242,prompt:blue,pointer:blue,hl:cyan,hl+:cyan' \
  --bind "ctrl-r:reload($_lst 2>/dev/null)" \
  --bind "z:execute-silent($_act toggle-collapse {})+reload($_lst 2>/dev/null)" \
  --bind "r:execute($_act rename {})+reload($_lst 2>/dev/null)" \
  --bind "d:execute($_act delete {})+reload($_lst 2>/dev/null)" \
  --bind "n:execute(AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") $(printf '%q' "$AID_DIR/lib/orchestrator.sh") --new)+abort" \
  --bind "q:abort" \
  --bind "esc:abort" \
  2>/dev/null \
  || true)

# _selected is field 2 (--accept-nth=2); strip any residual brackets.
_selected=$(printf '%s' "${_selected:-}" | tr -d '[]')

case "${_selected:-}" in
  "")
    exit 0
    ;;
  __header__*)
    # Enter on a header → toggle collapse, reopen navigator.
    _project="${_selected#__header__}"
    if grep -qxF "$_project" "$AID_SESSIONS_COLLAPSE" 2>/dev/null; then
      grep -vxF "$_project" "$AID_SESSIONS_COLLAPSE" > "${AID_SESSIONS_COLLAPSE}.tmp" \
        && mv "${AID_SESSIONS_COLLAPSE}.tmp" "$AID_SESSIONS_COLLAPSE" || true
    else
      printf '%s\n' "$_project" >> "$AID_SESSIONS_COLLAPSE"
    fi
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  __dead__*)
    _real_session="${_selected#__dead__}"
    _repo=$(_meta_get "$_real_session" "repo_path")
    _project=$(printf '%s' "$_real_session" | cut -d'@' -f2 | cut -d'/' -f1)
    _slug=$(printf '%s' "$_real_session"    | cut -d'/' -f2)
    if [[ -d "${_repo:-}" ]]; then
      exec "$AID_DIR/lib/orchestrator.sh" --resurrect "$_project" "$_slug" "$_repo"
    else
      echo "aid-sessions: repo path '${_repo}' no longer exists for session $_real_session" >&2
      exit 1
    fi
    ;;
  aid@*)
    _switch "$_selected"
    ;;
esac

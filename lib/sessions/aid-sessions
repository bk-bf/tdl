#!/usr/bin/env bash
# aid-sessions — orchestrator session navigator.
#
# Runs as a persistent left pane inside every aid@<name> tmux session.
# Also invocable standalone (e.g. via prefix+s popup in tmux.conf).
#
# Layout (left pane, ~25% width):
#   aid@my-project  [live]  /path/to/repo
#     > Some conversation title       3m ago    ← active conv (▶)
#       Another conversation         14m ago
#
#   aid@other-proj  [live]
#       A conversation               1h ago
#
#   aid@dead-proj   [dead]           2d ago
#
# Keys:
#   Enter  — if session header: switch tmux client to that session
#             if conversation:  load that conversation in the center opencode pane
#   n      — new session (prompts for name + repo)
#   d      — delete session (with confirmation)
#   r      — rename session
#   ctrl-r — manual refresh
#   q/esc  — quit
#
# Env: AID_DIR, AID_DATA, AID_CONFIG (all required)

set -euo pipefail

: "${AID_DIR:?}"
: "${AID_DATA:?}"

# shellcheck source=lib/sessions/aid-meta
source "$AID_DIR/lib/sessions/aid-meta"

# ── Mouse reset trap ──────────────────────────────────────────────────────────
# Prevents terminal corruption when fzf exits abnormally.
trap 'printf "\033[?1000l\033[?1002l\033[?1006l"' EXIT

# ── Caller client resolution ──────────────────────────────────────────────────
# Used to target display-popup and switch-client to the correct terminal.
if [[ -z "${AID_CALLER_CLIENT:-}" ]]; then
  if [[ -n "${TMUX_PANE:-}" ]]; then
    AID_CALLER_CLIENT=$(tmux -L aid display-message -t "$TMUX_PANE" \
      -p "#{client_tty}" 2>/dev/null || true)
  fi
  if [[ -z "${AID_CALLER_CLIENT:-}" ]]; then
    AID_CALLER_CLIENT=$(tty 2>/dev/null || true)
  fi
fi
export AID_CALLER_CLIENT

# ── Self-heal: ensure our own session is tagged as orchestrator ───────────────
# Sessions spawned before this tag logic existed (or after a restart) may be
# missing the @aid_mode option.  Tag ourselves now so aid-sessions-list finds us.
if [[ -n "${TMUX_PANE:-}" ]]; then
  _self_session=$(tmux -L aid display-message -t "$TMUX_PANE" \
    -p "#{session_name}" 2>/dev/null || true)
  if [[ -n "$_self_session" ]]; then
    _cur_tag=$(tmux -L aid show-options -t "$_self_session" "@aid_mode" 2>/dev/null \
      | awk '{print $2}' || true)
    if [[ "$_cur_tag" != "orchestrator" ]]; then
      tmux -L aid set-option -t "$_self_session" "@aid_mode" "orchestrator" 2>/dev/null || true
    fi
  fi
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

_aid_client_tty() {
  [[ -z "${AID_CALLER_CLIENT:-}" ]] && return 0
  tmux -L aid list-clients -F "#{client_tty}" 2>/dev/null \
    | grep -qxF "$AID_CALLER_CLIENT" && printf '%s' "$AID_CALLER_CLIENT" || true
}

_switch_to_session() {
  local target="$1"
  local _c; _c=$(_aid_client_tty)
  if [[ -n "$_c" ]]; then
    tmux -L aid switch-client -c "$_c" -t "$target"
  else
    tmux -L aid switch-client -t "$target"
  fi
}

_load_conversation() {
  local conv_id="$1" tmux_session="$2"

  # Get the opencode HTTP port for this session.
  local orc_port
  orc_port=$(tmux -L aid show-environment -t "$tmux_session" AID_ORC_PORT 2>/dev/null \
    | cut -d= -f2- || true)
  [[ -z "$orc_port" || "$orc_port" -le 0 ]] 2>/dev/null && return 0

  # Store the active conversation ID in the session env.
  tmux -L aid set-environment -t "$tmux_session" AID_ORC_ACTIVE_CONV "$conv_id"

  # Ask the live opencode TUI to switch to this session via HTTP API.
  # This does NOT kill or respawn the opencode pane — it sends a signal through
  # the running process, so the nav pane shell is unaffected.
  curl -sf --max-time 3 \
    -X POST \
    -H 'Content-Type: application/json' \
    -d "{\"sessionID\":\"${conv_id}\"}" \
    "http://127.0.0.1:${orc_port}/tui/select-session" \
    >/dev/null 2>&1 || true

  # If we're not already in that tmux session, switch to it.
  local _cur
  _cur=$(tmux -L aid display-message -p "#{session_name}" 2>/dev/null || true)
  [[ "$_cur" != "$tmux_session" ]] && _switch_to_session "$tmux_session"
}

_fzf_prompt() {
  local label="$1" default="$2"
  printf '%s' "$default" \
    | fzf --print-query \
          --query="$default" \
          --bind='enter:accept' \
          --bind='esc:abort' \
          --no-info \
          --no-sort \
          --height=4 \
          --border=rounded \
          --prompt="  ${label}: " \
          --color='border:238,prompt:blue' \
    | head -1
}

_do_rename() {
  local session="$1"
  case "$session" in dead:*|"") return ;; esac
  # Strip "session:" prefix if present.
  session="${session#session:}"
  local old_name new_name
  old_name="${session#aid@}"

  new_name=$(_fzf_prompt "rename" "$old_name") || return 0
  new_name=$(printf '%s' "${new_name:-}" | tr -cs '[:alnum:]-_.' '-' | sed 's/-$//')
  [[ -z "$new_name" || "$new_name" == "$old_name" ]] && return 0

  local new_session="aid@${new_name}"
  if tmux -L aid has-session -t "$new_session" 2>/dev/null; then
    printf 'error: session "%s" already exists\n' "$new_session"
    sleep 1
    return 0
  fi

  tmux -L aid rename-session -t "$session" "$new_session" 2>/dev/null || return 0
  local repo; repo=$(_meta_get "$session" "repo_path")
  _meta_write "$new_name" "${repo:-$PWD}"
  _meta_remove "$session"
}

_do_delete() {
  local tag="$1"
  local session
  case "$tag" in
    dead:*)    session="${tag#dead:}" ;;
    session:*) session="${tag#session:}" ;;
    *)         return ;;
  esac

  local confirm
  confirm=$(printf 'no\nyes' \
    | fzf --no-info \
          --no-sort \
          --height=5 \
          --border=rounded \
          --prompt="  delete ${session}? " \
          --color='border:238,prompt:yellow' \
    || true)
  [[ "$confirm" == "yes" ]] || return 0

  tmux -L aid kill-session -t "$session" 2>/dev/null || true
  _meta_remove "$session"
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v fzf &>/dev/null; then
  echo "aid-sessions: fzf not found" >&2
  exit 1
fi

# Auto-refresh port: pick a free port for fzf --listen so the background
# ticker can send reload commands without restarting fzf.
_fzf_port=$(( 49200 + RANDOM % 1000 ))

_act="AID_CALLER_CLIENT=$(printf '%q' "${AID_CALLER_CLIENT:-}") AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") TMUX=$(printf '%q' "${TMUX:-}") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-action")"
_lst="AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-list")"

# Background auto-refresh: every 5 s send a reload command to fzf via --listen.
(
  # Give fzf a moment to start and bind to the port.
  sleep 2
  while true; do
    sleep 5
    curl -sf --max-time 1 \
      -X POST \
      "http://127.0.0.1:${_fzf_port}" \
      -d "reload(${_lst} 2>/dev/null || true)" \
      >/dev/null 2>&1 || true
  done
) &
_ticker_pid=$!
trap 'kill "$_ticker_pid" 2>/dev/null || true; printf "\033[?1000l\033[?1002l\033[?1006l"' EXIT

# fzf main loop.
# - no --disabled, no search binds: search/filter is fully removed
# - change:ignore swallows typed characters so the list is never filtered
# - start:reload → immediate accurate list on open
# - ctrl-r:reload → manual refresh
# - n/r/d → new / rename / delete (via --expect)
# - q → quit
_output=$(printf '' | fzf \
  --listen="${_fzf_port}" \
  --border=rounded \
  --border-label=" aid sessions " \
  --border-label-pos=3 \
  --header=$'  \033[2menter\033[0m select  \033[2mn\033[0m new  \033[2mr\033[0m rename  \033[2md\033[0m delete  \033[2mctrl-r\033[0m refresh  \033[2mq\033[0m quit' \
  --layout=reverse-list \
  --no-sort \
  --no-input \
  --ansi \
  --delimiter=$'\t' \
  --with-nth=1 \
  --accept-nth='2' \
  --expect='n,r,d' \
  --preview="$_act preview {}" \
  --preview-window='right:45%:wrap:border-left:hidden' \
  --preview-label=' info ' \
  --color='border:238,label:blue,preview-border:238,preview-label:blue,header:italic:242,prompt:blue,pointer:blue,hl:cyan,hl+:cyan' \
  --bind "start:reload(${_lst} 2>/dev/null || true)" \
  --bind "ctrl-r:reload(${_lst} 2>/dev/null || true)" \
  --bind "esc:abort" \
  --bind "q:abort" \
  2>/dev/null \
  || true)

_key=$(printf '%s\n' "$_output" | head -1)
_tag=$(printf '%s\n' "$_output" | tail -n +2 | tr -d '[]')

case "$_key" in
  n)
    exec "$AID_DIR/lib/orchestrator.sh" --new
    ;;
  r)
    _do_rename "$_tag"
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  d)
    _do_delete "$_tag"
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
esac

# Enter: dispatch on tag type.
case "${_tag:-}" in
  ""|"(no sessions yet)"|sep)
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  session:*)
    _target="${_tag#session:}"
    _switch_to_session "$_target"
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  dead:*)
    _dead_session="${_tag#dead:}"
    _repo=$(_meta_get "$_dead_session" "repo_path")
    _name="${_dead_session#aid@}"
    if [[ -d "${_repo:-}" ]]; then
      exec "$AID_DIR/lib/orchestrator.sh" --resurrect "$_name" "$_repo"
    else
      echo "aid-sessions: repo '${_repo}' no longer exists for $_dead_session" >&2
      sleep 2
      exec "$AID_DIR/lib/sessions/aid-sessions"
    fi
    ;;
  conv:*)
    # Format: conv:<session_id>:<tmux_session>
    _rest="${_tag#conv:}"
    _conv_id="${_rest%%:*}"
    _tmux_session="${_rest#*:}"
    _load_conversation "$_conv_id" "$_tmux_session"
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  noconv:*)
    # No conversations — just re-open navigator.
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  *)
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
esac

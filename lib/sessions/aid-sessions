#!/usr/bin/env bash
# aid-sessions — orchestrator session navigator.
#
# Runs as a persistent left pane inside every aid@<name> tmux session.
# Also invocable standalone (e.g. via prefix+s popup in tmux.conf).
#
# Layout (left pane, ~25% width):
#   aid@my-project  [live]  /path/to/repo
#     > Some conversation title       3m ago    ← active conv (▶)
#       Another conversation         14m ago
#
#   aid@other-proj  [live]
#       A conversation               1h ago
#
#   aid@dead-proj   [dead]           2d ago
#
# Keys:
#   Enter  — if session header: switch tmux client to that session
#             if conversation:  load that conversation in the center opencode pane
#   n      — new session (prompts for name + repo)
#   d      — delete session (with confirmation)
#   r      — rename session
#   ctrl-r — manual refresh
#   q/esc  — quit
#
# Env: AID_DIR, AID_DATA, AID_CONFIG (all required)

set -euo pipefail

: "${AID_DIR:?}"
: "${AID_DATA:?}"

# shellcheck source=lib/sessions/aid-meta
source "$AID_DIR/lib/sessions/aid-meta"

# ── Debug logging ─────────────────────────────────────────────────────────────
# Writes timestamped events to AID_DEBUG_LOG when set (i.e. aid -d was used).
# Format: "<unix_ms> <CATEGORY> <message>"
_dbg() {
  [[ -z "${AID_DEBUG_LOG:-}" ]] && return 0
  local cat="$1"; shift
  local ms; ms=$(date +%s%3N 2>/dev/null || printf '%s000' "$(date +%s)")
  printf '%s %s %s\n' "$ms" "$cat" "$*" >> "$AID_DEBUG_LOG"
}

# ── Mouse reset trap ──────────────────────────────────────────────────────────
# Prevents terminal corruption when fzf exits abnormally.
trap 'printf "\033[?1000l\033[?1002l\033[?1006l"' EXIT

# ── Caller client resolution ──────────────────────────────────────────────────
# Used to target display-popup and switch-client to the correct terminal.
if [[ -z "${AID_CALLER_CLIENT:-}" ]]; then
  if [[ -n "${TMUX_PANE:-}" ]]; then
    AID_CALLER_CLIENT=$(tmux -L aid display-message -t "$TMUX_PANE" \
      -p "#{client_tty}" 2>/dev/null || true)
  fi
  if [[ -z "${AID_CALLER_CLIENT:-}" ]]; then
    AID_CALLER_CLIENT=$(tty 2>/dev/null || true)
  fi
fi
export AID_CALLER_CLIENT

# ── Self-heal: ensure our own session is tagged as orchestrator ───────────────
# Sessions spawned before this tag logic existed (or after a restart) may be
# missing the @aid_mode option.  Tag ourselves now so aid-sessions-list finds us.
if [[ -n "${TMUX_PANE:-}" ]]; then
  _self_session=$(tmux -L aid display-message -t "$TMUX_PANE" \
    -p "#{session_name}" 2>/dev/null || true)
  if [[ -n "$_self_session" ]]; then
    _cur_tag=$(tmux -L aid show-options -t "$_self_session" "@aid_mode" 2>/dev/null \
      | awk '{print $2}' || true)
    if [[ "$_cur_tag" != "orchestrator" ]]; then
      tmux -L aid set-option -t "$_self_session" "@aid_mode" "orchestrator" 2>/dev/null || true
    fi
  fi
fi

_dbg INIT "aid-sessions starting (pid=$$, pane=${TMUX_PANE:-?}, port will be assigned below)"

# ── Auto-prune dead sessions from metadata ────────────────────────────────────
# Remove any session from sessions.json that no longer exists in tmux.
# Dead sessions accumulate when tmux sessions are killed externally (e.g.
# server restart) without going through aid's delete flow.
# Runs once at startup; the fzf list is therefore always clean on open.
_prune_dead_sessions() {
  command -v jq &>/dev/null || return 0
  local _all_meta _session _pruned=0
  _all_meta=$(_meta_all_sessions 2>/dev/null || true)
  [[ -z "$_all_meta" ]] && return 0
  while IFS= read -r _session; do
    [[ -z "$_session" ]] && continue
    if ! tmux -L aid has-session -t "$_session" 2>/dev/null; then
      _dbg PRUNE "removing dead session from metadata: ${_session}"
      _meta_remove "$_session"
      _pruned=$(( _pruned + 1 ))
    fi
  done <<< "$_all_meta"
  [[ "$_pruned" -gt 0 ]] && _dbg PRUNE "pruned ${_pruned} dead session(s) from metadata"
}
_prune_dead_sessions

# ── Helpers ───────────────────────────────────────────────────────────────────

_aid_client_tty() {
  [[ -z "${AID_CALLER_CLIENT:-}" ]] && return 0
  tmux -L aid list-clients -F "#{client_tty}" 2>/dev/null \
    | grep -qxF "$AID_CALLER_CLIENT" && printf '%s' "$AID_CALLER_CLIENT" || true
}

_switch_to_session() {
  local target="$1"
  local _c; _c=$(_aid_client_tty)
  if [[ -n "$_c" ]]; then
    tmux -L aid switch-client -c "$_c" -t "$target"
  else
    tmux -L aid switch-client -t "$target"
  fi
}

_load_conversation() {
  local conv_id="$1" tmux_session="$2"

  # Get the opencode HTTP port for this session.
  local orc_port
  orc_port=$(tmux -L aid show-environment -t "$tmux_session" AID_ORC_PORT 2>/dev/null \
    | cut -d= -f2- || true)
  [[ -z "$orc_port" || "$orc_port" -le 0 ]] 2>/dev/null && return 0

  _dbg CONV "load conv_id=${conv_id} session=${tmux_session} port=${orc_port}"

  # Store the active conversation ID in the session env.
  tmux -L aid set-environment -t "$tmux_session" AID_ORC_ACTIVE_CONV "$conv_id"

  # Ask the live opencode TUI to switch to this session via HTTP API.
  # This does NOT kill or respawn the opencode pane — it sends a signal through
  # the running process, so the nav pane shell is unaffected.
  local _curl_rc=0
  curl -sf --max-time 3 \
    -X POST \
    -H 'Content-Type: application/json' \
    -d "{\"sessionID\":\"${conv_id}\"}" \
    "http://127.0.0.1:${orc_port}/tui/select-session" \
    >/dev/null 2>&1 || _curl_rc=$?
  _dbg CONV "select-session curl rc=${_curl_rc} conv_id=${conv_id}"

  # If we're not already in that tmux session, switch to it.
  local _cur
  _cur=$(tmux -L aid display-message -p "#{session_name}" 2>/dev/null || true)
  [[ "$_cur" != "$tmux_session" ]] && _switch_to_session "$tmux_session"
}

_fzf_prompt() {
  local label="$1" default="$2"
  # Empty stdin from /dev/null; fzf reads the tty for its UI.
  # --print-query returns whatever the user typed (ignoring any item list).
  fzf --print-query \
      --query="$default" \
      --bind='enter:accept' \
      --bind='esc:abort' \
      --no-info \
      --no-sort \
      --height=4 \
      --border=rounded \
      --prompt="  ${label}: " \
      --color='border:238,prompt:blue' \
      < /dev/null \
    | head -1
}

_do_rename() {
  local session="$1"
  case "$session" in dead:*|"") return ;; esac
  # Strip "session:" prefix if present.
  session="${session#session:}"
  local old_name new_name
  old_name="${session#aid@}"

  _dbg RENAME "prompt for rename of ${session}"
  new_name=$(_fzf_prompt "rename" "$old_name") || return 0
  new_name=$(printf '%s' "${new_name:-}" | tr -cs '[:alnum:]-_.' '-' | sed 's/-$//')
  [[ -z "$new_name" || "$new_name" == "$old_name" ]] && return 0

  local new_session="aid@${new_name}"
  if tmux -L aid has-session -t "$new_session" 2>/dev/null; then
    printf 'error: session "%s" already exists\n' "$new_session"
    sleep 1
    return 0
  fi

  _dbg RENAME "renaming ${session} -> ${new_session}"
  tmux -L aid rename-session -t "$session" "$new_session" 2>/dev/null || return 0
  local repo; repo=$(_meta_get "$session" "repo_path")
  _meta_write "$new_name" "${repo:-$PWD}"
  _meta_remove "$session"
  _dbg RENAME "done: old=${session} new=${new_session}"
}

_do_delete() {
  local tag="$1"
  local session
  case "$tag" in
    dead:*)    session="${tag#dead:}" ;;
    session:*) session="${tag#session:}" ;;
    *)         return ;;
  esac

  _dbg DEL "confirm prompt for ${session}"
  local confirm
  confirm=$(fzf --no-info \
      --no-sort \
      --height=5 \
      --border=rounded \
      --prompt="  delete ${session}? " \
      --color='border:238,prompt:yellow' \
      --bind="start:reload(printf 'no\nyes')" \
      < /dev/null \
    || true)
  if [[ "$confirm" != "yes" ]]; then
    _dbg DEL "delete cancelled (confirm='${confirm:-<empty>}') for ${session}"
    return 0
  fi

  _dbg DEL "deleting ${session}"
  tmux -L aid kill-session -t "$session" 2>/dev/null || true
  _meta_remove "$session"
  _dbg DEL "done: removed ${session}"
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v fzf &>/dev/null; then
  echo "aid-sessions: fzf not found" >&2
  exit 1
fi

# Auto-refresh port: pick a free port for fzf --listen so the background
# ticker can send reload commands without restarting fzf.
_fzf_port=$(( 49200 + RANDOM % 1000 ))
_dbg INIT "fzf --listen port=${_fzf_port}"

_act="AID_CALLER_CLIENT=$(printf '%q' "${AID_CALLER_CLIENT:-}") AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") TMUX=$(printf '%q' "${TMUX:-}") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-action")"
_lst="AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-list")"
_dbglog=$(printf '%q' "${AID_DEBUG_LOG:-}")
# Quoted invocation of the reload helper — shared by ticker and ctrl-r.
# The helper reads FZF_POS / FZF_MATCH_COUNT from its env (set by fzf) and
# emits a reload-sync+pos action string to stdout.
_rld="AID_DEBUG_LOG=${_dbglog} AID_SESSIONS_LST=$(printf '%q' "${_lst}") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-reload")"

_dbg INIT "vars ready: act/lst/rld/dbglog set"

# Background auto-refresh: every 5 s send a reload command to fzf via --listen.
# Spawned ONCE here — never re-spawned across loop iterations (Bug 2 fix).
# Uses transform so fzf sets FZF_POS in the shell env; aid-sessions-reload reads
# it and emits reload-sync+pos, preserving the cursor across auto-refreshes.
(
  # Give fzf a moment to start and bind to the port.
  # Log when the ticker wakes up so the timeline is visible in the debug log.
  if [[ -n "${AID_DEBUG_LOG:-}" ]]; then
    _ms=$(date +%s%3N 2>/dev/null || printf '%s000' "$(date +%s)")
    printf '%s TICK  ticker sleeping 2s before first attempt (port=%s)\n' \
      "$_ms" "${_fzf_port}" >> "${AID_DEBUG_LOG}"
  fi
  sleep 2
  # Fire an immediate reload right after warmup (tick=0) so opencode
  # conversations appear as soon as the HTTP port is ready (~1-2s after
  # launch), rather than waiting for the first regular tick at +7s.
  _tick=0
  while true; do
    _rc=0
    curl -sf --max-time 1 \
      -X POST \
      "http://127.0.0.1:${_fzf_port}" \
      -d "transform:${_rld} tick=${_tick}" \
      >/dev/null 2>&1 || _rc=$?
    if [[ -n "${AID_DEBUG_LOG:-}" ]]; then
      _ms=$(date +%s%3N 2>/dev/null || printf '%s000' "$(date +%s)")
      if [[ "$_rc" -ne 0 ]]; then
        printf '%s ERR   ticker curl failed (rc=%s, port=%s, tick=%s)\n' "$_ms" "$_rc" "${_fzf_port}" "$_tick" >> "${AID_DEBUG_LOG}"
      else
        printf '%s HTTP  ticker POST ok (tick=%s)\n' "$_ms" "$_tick" >> "${AID_DEBUG_LOG}"
      fi
    fi
    _tick=$(( _tick + 1 ))
    sleep 5
  done
) &
_ticker_pid=$!
trap 'kill "$_ticker_pid" 2>/dev/null || true; printf "\033[?1000l\033[?1002l\033[?1006l"' EXIT

# ── fzf loop ──────────────────────────────────────────────────────────────────
# Instead of exec-ing back into aid-sessions on every action (which orphans the
# ticker above), we loop here.  fzf is restarted inside this process; the ticker
# keeps running against the same port.
#
# _start_pos: cursor row to restore when fzf reopens after a rename/delete/etc.
# Defaults to 1; set to the last known FZF_POS before fzf exits so the user
# lands near where they were (Bug 4 fix).
_start_pos=1

while true; do
  # Pre-populate fzf stdin with the current list so there is no blank flash on
  # open (Bug 5 fix).  We run the list command here in the shell, pipe it
  # directly to fzf, and skip the start:reload-sync approach entirely.
  # The ticker and ctrl-r still use reload-sync for subsequent updates.
  _dbg STDIN "running list command before fzf open (start_pos=${_start_pos})"
  _initial_list=$(eval "$_lst" 2>/dev/null || true)
  _initial_lines=$(printf '%s' "$_initial_list" | wc -l)
  # Detect if opencode HTTP ports weren't ready yet (noconv: placeholders present).
  if printf '%s' "$_initial_list" | grep -q '\[noconv:'; then
    _dbg STDIN "list has noconv: entries — opencode port(s) not ready yet; ticker will fix at +2s"
  fi
  _dbg STDIN "list ready: ${_initial_lines} lines"

  _output=$(printf '%s\n' "$_initial_list" | fzf \
    --listen="${_fzf_port}" \
    --border=rounded \
    --border-label=" aid sessions " \
    --border-label-pos=3 \
    --header=$'  \033[2menter\033[0m select  \033[2mn\033[0m new  \033[2mr\033[0m rename  \033[2md\033[0m delete  \033[2mctrl-r\033[0m refresh  \033[2mq\033[0m quit' \
    --layout=reverse-list \
    --no-sort \
    --no-input \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --accept-nth='2' \
    --expect='n,r,d' \
    --preview="$_act preview {}" \
    --preview-window='right:45%:wrap:border-left:hidden' \
    --preview-label=' info ' \
    --color='border:238,label:blue,preview-border:238,preview-label:blue,header:italic:242,prompt:blue,pointer:blue,hl:cyan,hl+:cyan' \
    --bind "start:pos(${_start_pos})" \
    --bind "ctrl-r:transform:${_rld} ctrl-r" \
    --bind "focus:execute-silent:
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s POS   focus FZF_POS=%s FZF_ACTION=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" \"\${FZF_ACTION:-?}\" >> ${_dbglog}
    " \
    --bind "load:execute-silent:
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s LOAD  list ready FZF_POS=%s FZF_MATCH_COUNT=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" \"\${FZF_MATCH_COUNT:-?}\" >> ${_dbglog}
    " \
    --bind "up:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s KEY   up FZF_POS=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )+up" \
    --bind "down:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s KEY   down FZF_POS=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )+down" \
    --bind "page-up:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s KEY   page-up FZF_POS=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )+page-up" \
    --bind "page-down:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s KEY   page-down FZF_POS=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )+page-down" \
    --bind "enter:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s KEY   enter FZF_POS=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )+accept" \
    --bind "esc:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s KEY   esc (quit)\n' \"\$_ms\" >> ${_dbglog}
    )+abort" \
    --bind "q:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s KEY   q (quit)\n' \"\$_ms\" >> ${_dbglog}
    )+abort" \
    --bind "n:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s ACTN  n (new session) FZF_POS=%s\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )" \
    --bind "r:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s ACTN  r (rename) FZF_POS=%s tag={2}\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )" \
    --bind "d:execute-silent(
      _ms=\$(date +%s%3N 2>/dev/null || printf '%s000' \"\$(date +%s)\")
      [[ -n ${_dbglog} ]] && printf '%s ACTN  d (delete) FZF_POS=%s tag={2}\n' \"\$_ms\" \"\${FZF_POS:-?}\" >> ${_dbglog}
    )" \
    2>/dev/null \
    || true)

  _key=$(printf '%s\n' "$_output" | head -1)
  _tag=$(printf '%s\n' "$_output" | tail -n +2 | tr -d '[]')

  _dbg KEY "fzf exited key='${_key:-enter}' tag='${_tag:-}' pos=${_start_pos}"

  # Default: reopen at row 1 unless overridden below.
  _start_pos=1

  case "$_key" in
    n)
      _dbg ACTN "n: spawning new session"
      exec "$AID_DIR/lib/orchestrator.sh" --new
      ;;
    r)
      _dbg ACTN "r: rename tag='${_tag:-}'"
      _do_rename "$_tag"
      _start_pos=1
      continue
      ;;
    d)
      _dbg ACTN "d: delete tag='${_tag:-}'"
      _do_delete "$_tag"
      _start_pos=1
      continue
      ;;
  esac

  # Enter: dispatch on tag type.
  case "${_tag:-}" in
    ""|"(no sessions yet)"|sep)
      _dbg ACTN "enter: ignored (tag='${_tag:-}')"
      continue
      ;;
    session:*)
      _target="${_tag#session:}"
      _dbg ACTN "enter: switch to session ${_target}"
      _switch_to_session "$_target"
      continue
      ;;
    dead:*)
      _dead_session="${_tag#dead:}"
      _repo=$(_meta_get "$_dead_session" "repo_path")
      _name="${_dead_session#aid@}"
      _dbg ACTN "enter: resurrect dead session ${_dead_session} repo=${_repo:-<none>}"
      if [[ -d "${_repo:-}" ]]; then
        exec "$AID_DIR/lib/orchestrator.sh" --resurrect "$_name" "$_repo"
      else
        _dbg ACTN "enter: repo missing for ${_dead_session}, cannot resurrect"
        echo "aid-sessions: repo '${_repo}' no longer exists for $_dead_session" >&2
        sleep 2
        continue
      fi
      ;;
    conv:*)
      # Format: conv:<session_id>:<tmux_session>
      _rest="${_tag#conv:}"
      _conv_id="${_rest%%:*}"
      _tmux_session="${_rest#*:}"
      _dbg ACTN "enter: load conv ${_conv_id} in session ${_tmux_session}"
      _load_conversation "$_conv_id" "$_tmux_session"
      continue
      ;;
    noconv:*)
      _dbg ACTN "enter: ignored (noconv tag)"
      continue
      ;;
    *)
      continue
      ;;
  esac
done

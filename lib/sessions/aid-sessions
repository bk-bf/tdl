#!/usr/bin/env bash
# aid-sessions — orchestrator session navigator (T-ORC-5: enhanced fzf TUI).
#
# Displays all aid@<project>/<slug> tmux sessions in a rich fzf interface:
#   - Project group headers with collapse/expand  (z)
#   - Branch names and activity status from metadata
#   - Preview pane: repo path, branch, git status, timestamps
#   - Dead session resurrection                   (Enter on dead session)
#   - Rename session                              (r)
#   - Delete session with cleanup                 (d)
#   - New session                                 (n)
#   - Manual refresh                              (ctrl-r)
#
# Invoked by:
#   - orchestrator.sh when sessions already exist
#   - tmux.conf prefix+s binding: tmux display-popup -E "$AID_DIR/aid-sessions"
#
# Requirements: fzf >= 0.57
#
# Architecture: fzf is a pure selector — n/r/d exit fzf via --expect and are
# handled inline in this script, then the navigator re-execs.  This avoids
# any nested-fzf-inside-execute() problems (no tty ownership conflicts).

set -euo pipefail

: "${AID_DIR:?}"
: "${AID_DATA:?}"

# shellcheck source=lib/sessions/aid-meta
source "$AID_DIR/lib/sessions/aid-meta"

# ── Collapse state ────────────────────────────────────────────────────────────
# Tmpfile listing collapsed project names, one per line.
# Exported so aid-sessions-list and aid-sessions-action can read it.
export AID_SESSIONS_COLLAPSE
AID_SESSIONS_COLLAPSE=$(mktemp /tmp/aid-sessions-collapse.XXXXXX)
trap 'rm -f "$AID_SESSIONS_COLLAPSE"; printf "\033[?1000l\033[?1002l\033[?1006l"' EXIT

# ── AID_CALLER_CLIENT ─────────────────────────────────────────────────────────
# Tty of the terminal that opened this navigator.
# Inherited from orchestrator.sh when launched via display-popup; derived here
# otherwise.  Resolution order: inherited > TMUX_PANE lookup > tty fallback.
if [[ -z "${AID_CALLER_CLIENT:-}" ]]; then
  if [[ -n "${TMUX_PANE:-}" ]]; then
    AID_CALLER_CLIENT=$(tmux -L aid display-message -t "$TMUX_PANE" -p "#{client_tty}" 2>/dev/null || true)
  fi
  if [[ -z "${AID_CALLER_CLIENT:-}" ]]; then
    AID_CALLER_CLIENT=$(tty 2>/dev/null || true)
  fi
fi
export AID_CALLER_CLIENT

# ── Helpers ───────────────────────────────────────────────────────────────────

_switch() {
  local session="$1"
  if [[ -n "${TMUX:-}" ]]; then
    # Only use -c when AID_CALLER_CLIENT is a known client of the aid server.
    local _c=""
    if [[ -n "${AID_CALLER_CLIENT:-}" ]] && \
       tmux -L aid list-clients -F "#{client_tty}" 2>/dev/null \
         | grep -qxF "$AID_CALLER_CLIENT"; then
      _c="$AID_CALLER_CLIENT"
    fi
    if [[ -n "$_c" ]]; then
      tmux -L aid switch-client -c "$_c" -t "$session"
    else
      tmux -L aid switch-client -t "$session"
    fi
  else
    tmux -L aid attach -t "$session"
  fi
}

_fzf_prompt() {
  local label="$1" default="$2"
  printf '%s' "$default" \
    | fzf --print-query \
          --query="$default" \
          --bind='enter:accept' \
          --bind='esc:abort' \
          --no-info \
          --no-sort \
          --height=4 \
          --border=rounded \
          --prompt="  ${label}: " \
          --color='border:238,prompt:blue' \
    | head -1
}

_do_rename() {
  local session="$1"
  case "$session" in __dead__*|__header__*) return ;; esac
  local old_slug project new_slug
  old_slug=$(printf '%s' "$session" | cut -d'/' -f2)
  project=$(printf '%s' "$session"  | cut -d'@' -f2 | cut -d'/' -f1)

  new_slug=$(_fzf_prompt "rename slug" "$old_slug") || return 0
  new_slug=$(printf '%s' "${new_slug:-}" | tr -cs '[:alnum:]-_' '-' | sed 's/-$//')
  [[ -z "$new_slug" || "$new_slug" == "$old_slug" ]] && return 0

  local new_session="aid@${project}/${new_slug}"
  if tmux -L aid has-session -t "$new_session" 2>/dev/null; then
    printf 'error: session "%s" already exists\n' "$new_session"
    sleep 1
    return 0
  fi

  tmux -L aid rename-session -t "$session" "$new_session" 2>/dev/null || return 0
  local repo; repo=$(_meta_get "$session" "repo_path")
  _meta_write "$project" "$new_slug" "${repo:-$PWD}"
  _meta_remove "$session"
}

_do_delete() {
  local session="$1"
  case "$session" in __header__*) return ;; esac
  case "$session" in
    __dead__*) session="${session#__dead__}" ;;
  esac

  local confirm
  confirm=$(printf 'no\nyes' \
    | fzf --no-info \
          --no-sort \
          --height=5 \
          --border=rounded \
          --prompt="  delete ${session}? " \
          --color='border:238,prompt:yellow' \
    || true)
  [[ "$confirm" == "yes" ]] || return 0

  tmux -L aid kill-session -t "$session" 2>/dev/null || true
  _meta_remove "$session"
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v fzf &>/dev/null; then
  echo "aid-sessions: fzf not found — install fzf for the session navigator" >&2
  tmux -L aid list-sessions -F "#{session_name}" 2>/dev/null \
    | grep -E '^aid@[^/]+/[^/]+$' || true
  exit 1
fi

# Pre-build the action and reload command strings (expanded once, safe paths).
_act="AID_CALLER_CLIENT=$(printf '%q' "${AID_CALLER_CLIENT:-}") AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") AID_SESSIONS_COLLAPSE=$(printf '%q' "$AID_SESSIONS_COLLAPSE") TMUX=$(printf '%q' "${TMUX:-}") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-action")"
_lst="AID_DATA=$(printf '%q' "$AID_DATA") AID_DIR=$(printf '%q' "$AID_DIR") AID_SESSIONS_COLLAPSE=$(printf '%q' "$AID_SESSIONS_COLLAPSE") $(printf '%q' "$AID_DIR/lib/sessions/aid-sessions-list")"

_initial_list=$("$AID_DIR/lib/sessions/aid-sessions-list" 2>/dev/null || true)

if [[ -z "$_initial_list" ]]; then
  echo "no orchestrator sessions — run: aid --mode orchestrator"
  exit 0
fi

# fzf is a pure selector.  n/r/d are captured via --expect so fzf exits and
# this script handles the action inline (no nested fzf inside execute()).
_output=$(printf '%s\n' "$_initial_list" | fzf \
  --prompt="  " \
  --border=rounded \
  --border-label=" aid sessions " \
  --border-label-pos=3 \
  --header=$'  \033[2menter\033[0m switch  \033[2mn\033[0m new  \033[2mr\033[0m rename  \033[2md\033[0m delete  \033[2mz\033[0m collapse  \033[2mctrl-r\033[0m refresh  \033[2mq/esc\033[0m quit' \
  --no-sort \
  --ansi \
  --delimiter='\t' \
  --with-nth=1 \
  --accept-nth='2' \
  --expect='n,r,d' \
  --preview="$_act preview {}" \
  --preview-window='right:42%:wrap:border-left' \
  --preview-label=' info ' \
  --color='border:238,label:blue,preview-border:238,preview-label:blue,header:italic:242,prompt:blue,pointer:blue,hl:cyan,hl+:cyan' \
  --bind "ctrl-r:reload($_lst 2>/dev/null)" \
  --bind "z:execute-silent($_act toggle-collapse {})+reload($_lst 2>/dev/null)" \
  --bind "q:abort" \
  --bind "esc:abort" \
  2>/dev/null \
  || true)

# Parse output: line 1 = key pressed (empty = enter), line 2 = selected item.
_key=$(printf '%s' "$_output" | head -1)
_selected=$(printf '%s' "$_output" | tail -n +2 | tr -d '[]')

case "$_key" in
  n)
    # New session — run prompt inline then re-open navigator.
    export AID_IN_NEW_POPUP=1
    exec "$AID_DIR/lib/orchestrator.sh" --new
    ;;
  r)
    # Rename — run inline fzf prompt then re-open navigator.
    _do_rename "$_selected"
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  d)
    # Delete — run inline fzf prompt then re-open navigator.
    _do_delete "$_selected"
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
esac

# enter key — dispatch on selected item tag.
case "${_selected:-}" in
  "")
    exit 0
    ;;
  __header__*)
    _project="${_selected#__header__}"
    if grep -qxF "$_project" "$AID_SESSIONS_COLLAPSE" 2>/dev/null; then
      grep -vxF "$_project" "$AID_SESSIONS_COLLAPSE" > "${AID_SESSIONS_COLLAPSE}.tmp" \
        && mv "${AID_SESSIONS_COLLAPSE}.tmp" "$AID_SESSIONS_COLLAPSE" || true
    else
      printf '%s\n' "$_project" >> "$AID_SESSIONS_COLLAPSE"
    fi
    exec "$AID_DIR/lib/sessions/aid-sessions"
    ;;
  __dead__*)
    _real_session="${_selected#__dead__}"
    _repo=$(_meta_get "$_real_session" "repo_path")
    _project=$(printf '%s' "$_real_session" | cut -d'@' -f2 | cut -d'/' -f1)
    _slug=$(printf '%s' "$_real_session"    | cut -d'/' -f2)
    if [[ -d "${_repo:-}" ]]; then
      exec "$AID_DIR/lib/orchestrator.sh" --resurrect "$_project" "$_slug" "$_repo"
    else
      echo "aid-sessions: repo path '${_repo}' no longer exists for session $_real_session" >&2
      exit 1
    fi
    ;;
  aid@*)
    _switch "$_selected"
    ;;
esac

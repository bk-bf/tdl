#!/usr/bin/env bash
# aid-sessions-debug вҖ” live debug log viewer for the aid-sessions navigator.
#
# Runs in a dedicated tmux pane (bottom of the orchestrator layout).
# Tails AID_DEBUG_LOG and renders each event with colour-coded prefixes and
# a +О”ms delta column showing elapsed time since the previous event.
#
# Log format written by aid-sessions / aid-sessions-reload:
#   <unix_ms> <category> <message>
#
# Categories:
#   INIT   вҖ” startup events
#   SYNC   вҖ” reload-sync action dispatched (with label and FZF_POS)
#   LOAD   вҖ” fzf list fully loaded (load: event)
#   POS    вҖ” cursor position snapshot (focus: event)
#   KEY    вҖ” key / action from user
#   HTTP   вҖ” curl result for --listen POST
#   CONV   вҖ” conversation load request
#   ERR    вҖ” error
#
# Viewer controls (less):
#   F      вҖ” toggle follow mode (like tail -f)
#   q      вҖ” quit / detach viewer (does not stop the session)
#
# Env: AID_DEBUG_LOG (path to log file; required)

set -euo pipefail

: "${AID_DEBUG_LOG:?AID_DEBUG_LOG must be set}"

# Create log file if it doesn't exist yet.
mkdir -p "$(dirname "$AID_DEBUG_LOG")"
touch "$AID_DEBUG_LOG"

# Colour map per category.
_colour() {
  case "$1" in
    INIT)   printf '\033[1;34m'   ;;   # bold blue
    SYNC)   printf '\033[1;32m'   ;;   # bold green   (reload-sync dispatched)
    LOAD)   printf '\033[0;32m'   ;;   # green        (list ready)
    POS)    printf '\033[1;33m'   ;;   # bold yellow  (cursor position)
    KEY)    printf '\033[1;35m'   ;;   # bold magenta
    HTTP)   printf '\033[0;36m'   ;;   # cyan
    CONV)   printf '\033[1;36m'   ;;   # bold cyan    (conversation load)
    ERR)    printf '\033[1;31m'   ;;   # bold red
    *)      printf '\033[0m'      ;;
  esac
}
_reset() { printf '\033[0m'; }

# Format a delta (ms since previous event) for display.
_fmt_delta() {
  local delta="$1"
  if   (( delta < 0     )); then printf '\033[2m      \033[0m'          # negative = clock skew, hide
  elif (( delta < 10    )); then printf '\033[2m+%3dms\033[0m' "$delta" # dim for tiny deltas
  elif (( delta < 100   )); then printf '\033[0m+%3dms\033[0m' "$delta"
  elif (( delta < 1000  )); then printf '\033[1;33m+%3dms\033[0m' "$delta"   # yellow when >100ms
  else                           printf '\033[1;31m+%3ds \033[0m' "$(( delta / 1000 ))"  # red when >1s
  fi
}

# Header banner.
printf '\033[1;34mв”Ңв”Җ aid-sessions debug log в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\033[0m\n'
printf '\033[2m  log: %s\033[0m\n' "$AID_DEBUG_LOG"
printf '\033[2m  F = follow mode, q = quit viewer\033[0m\n'
printf '\033[1;34mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\033[0m\n'

# Process each log line: add delta, colour, format вҖ” then pipe into less.
# less +F starts in follow mode; the user can press F to pause/scroll and F again to resume.
tail -F "$AID_DEBUG_LOG" 2>/dev/null | while IFS= read -r line; do
  # Expected format: "<ms> <CAT> <rest>"
  ms="${line%% *}"
  rest="${line#* }"
  cat="${rest%% *}"
  msg="${rest#* }"

  # Sanitise: replace literal '?' FZF_POS value with '-' for readability.
  msg="${msg//FZF_POS=?/FZF_POS=-}"
  msg="${msg//match_count=?/match_count=-}"

  # Convert ms to HH:MM:SS.mmm
  ts_s=$(( ms / 1000 ))
  ts_ms=$(( ms % 1000 ))
  ts=$(date -d "@${ts_s}" '+%H:%M:%S' 2>/dev/null \
    || date -r  "${ts_s}" '+%H:%M:%S' 2>/dev/null \
    || printf '%s' "$ts_s")
  ts_full=$(printf '%s.%03d' "$ts" "$ts_ms")

  # Delta since previous event.
  _prev_ms="${_prev_ms:-$ms}"
  delta=$(( ms - _prev_ms ))
  _prev_ms="$ms"

  col=$(_colour "$cat")
  rst=$(_reset)
  delta_str=$(_fmt_delta "$delta")

  printf '%s\033[2m%s\033[0m %s %s%-7s%s %s\n' \
    "" "$ts_full" "$delta_str" "$col" "$cat" "$rst" "$msg"
done

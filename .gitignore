# ── personal dev tooling (not for distribution) ──────────────────────────────
# .nvim.lua      — per-developer exrc (formatter/linter wiring, local overrides)
# selene.toml    — selene linter config (only meaningful if selene is installed)
# stylua.toml    — StyLua formatter config
# .luarc.json    — LuaLS workspace config (suppresses false-positive vim globals)
# opencode.json  — per-project opencode LSP/config (bootstrapped from template)
.nvim.lua
!nvim/templates/.nvim.lua
selene.toml
stylua.toml
.luarc.json
opencode.json
!nvim/templates/opencode.json

# ── nvim-treemux ─────────────────────────────────────────────────────────────
nvim-treemux/lazy-lock.json

# ── opencode ──────────────────────────────────────────────────────────────────
# Source: opencode/commands/  opencode/tui.json
# Runtime (written by opencode, not aid source):
opencode/node_modules/
opencode/.gitignore
opencode/package.json
opencode/bun.lock
opencode/bin/
opencode/log/
opencode/opencode.db
opencode/opencode.db-shm
opencode/opencode.db-wal
opencode/models.json
opencode/version

# ── tmux ──────────────────────────────────────────────────────────────────────
# palette.conf is generated at session start by gen-tmux-palette.sh
tmux/palette.conf
# plugins/ holds TPM and plugin clones installed by install.sh — not source.
# The directory itself (with .gitkeep + .gitignore) is tracked; its contents are not.
tmux/plugins/*
!tmux/plugins/.gitkeep
!tmux/plugins/.gitignore

# ── bun / TypeScript tooling ─────────────────────────────────────────────────
.bun/
node_modules/
package.json
bun.lock
bun.lockb

# ── nvim runtime artefacts ────────────────────────────────────────────────────
# These land under $AID_DIR/nvim/ only on stale/misconfigured installs.
# Correct target is ~/.local/{share,state,cache}/aid/nvim/.  Kept as safety net.
nvim/site/
nvim/undo/
nvim/lazy/

# ── lazygit ───────────────────────────────────────────────────────────────────
# lazygit config is redirected to ~/.config/aid/lazygit/ via LG_CONFIG_FILE.
# Any lazygit/ directory inside $AID_DIR is a stray write — ignore it.
lazygit/

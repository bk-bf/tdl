#!/usr/bin/env bash
# aid-sessions — orchestrator session navigator (Stage 1: fzf-based).
#
# Lists all aid@<project>/<slug> tmux sessions grouped by project.
# Also shows dead sessions from sessions.json (not in tmux) for resurrection.
# Invoked by:
#   - orchestrator.sh when sessions already exist
#   - tmux.conf prefix+s binding: tmux display-popup -E "$AID_DIR/aid-sessions"
#
# Keybinds (inside fzf):
#   Enter       switch to selected session (or resurrect dead session)
#   ctrl-n      create new session
#   ctrl-d      delete selected session (kill tmux session + remove metadata)
#   ctrl-r      refresh list
#   esc/ctrl-c  close navigator
#
# Requirements: fzf

set -euo pipefail

: "${AID_DIR:?}"
: "${AID_DATA:?}"

# shellcheck source=aid-meta
source "$AID_DIR/aid-meta"

# ── Helpers ───────────────────────────────────────────────────────────────────

_switch() {
  local session="$1"
  if [[ -n "${TMUX:-}" ]]; then
    tmux -L aid switch-client -t "$session"
  else
    tmux -L aid attach -t "$session"
  fi
}

# ── Session list builder ──────────────────────────────────────────────────────

_build_list() {
  # Live tmux sessions: aid@<project>/<slug>
  mapfile -t _live < <(
    tmux -L aid list-sessions -F "#{session_last_attached} #{session_name}" 2>/dev/null \
      | grep -E ' aid@[^/]+/[^/]+$' \
      | sort -rn \
      | awk '{print $2}'
  )

  # Dead sessions: in sessions.json but not in tmux.
  mapfile -t _dead < <(
    _meta_all_sessions | while IFS= read -r s; do
      printf '%s\n' "${_live[@]:-}" | grep -qxF "$s" || printf '%s\n' "$s"
    done || true
  )

  if [[ ${#_live[@]} -eq 0 ]] && [[ ${#_dead[@]} -eq 0 ]]; then
    return
  fi

  local _current_project=""

  # ── Live sessions ──
  for _session in "${_live[@]}"; do
    local _project _slug _activity _now _diff _status _active_marker _branch
    # Session format: aid@<project>/<slug>
    _project=$(printf '%s' "$_session" | cut -d'@' -f2 | cut -d'/' -f1)
    _slug=$(printf '%s' "$_session"    | cut -d'/' -f2)

    # Project group header.
    if [[ "$_project" != "$_current_project" ]]; then
      _current_project="$_project"
      printf 'HEADER: %s/\n' "$_project"
    fi

    # Activity status from pane_last_used timestamp.
    _activity=$(tmux -L aid list-panes -t "$_session" \
      -F "#{pane_last_used}" 2>/dev/null | head -1 || printf '0')
    _now=$(date +%s)
    _diff=$(( _now - _activity ))
    if   (( _diff < 60   )); then _status="running  ${_diff}s ago"
    elif (( _diff < 3600 )); then _status="idle     $(( _diff / 60 ))m ago"
    else                          _status="idle     $(( _diff / 3600 ))h ago"
    fi

    # Branch from metadata (graceful empty if jq absent or entry missing).
    _branch=$(_meta_get "$_session" "branch")
    [[ -n "$_branch" ]] && _branch=" [$_branch]" || _branch=""

    # Mark the currently attached session.
    _active_marker="  "
    if tmux -L aid display-message -p "#{session_name}" 2>/dev/null | grep -qxF "$_session"; then
      _active_marker="> "
    fi

    # Format: indent + marker + slug + branch + status + hidden session tag.
    printf '    %s%-24s%s %s\t[%s]\n' \
      "$_active_marker" "$_slug" "$_branch" "$_status" "$_session"
  done

  # ── Dead sessions (from metadata, not in tmux) ──
  for _session in "${_dead[@]}"; do
    local _project _slug _branch _last_active
    # Session format: aid@<project>/<slug>
    _project=$(printf '%s' "$_session" | cut -d'@' -f2 | cut -d'/' -f1)
    _slug=$(printf '%s' "$_session"    | cut -d'/' -f2)

    # Project group header.
    if [[ "$_project" != "$_current_project" ]]; then
      _current_project="$_project"
      printf 'HEADER: %s/\n' "$_project"
    fi

    _branch=$(_meta_get "$_session" "branch")
    [[ -n "$_branch" ]] && _branch=" [$_branch]" || _branch=""
    _last_active=$(_meta_get "$_session" "last_active")
    [[ -z "$_last_active" ]] && _last_active="unknown"

    # dead sessions are prefixed with "~" marker and tagged __dead__ for handling.
    printf '    ~ %-23s%s dead (last: %s)\t[__dead__%s]\n' \
      "$_slug" "$_branch" "$_last_active" "$_session"
  done
}

# ── Main ──────────────────────────────────────────────────────────────────────

if ! command -v fzf &>/dev/null; then
  echo "aid-sessions: fzf not found — install fzf for the session navigator" >&2
  tmux -L aid list-sessions -F "#{session_name}" 2>/dev/null \
    | grep -E '^aid@[^/]+/[^/]+$' || true
  exit 1
fi

_list=$(_build_list)

if [[ -z "$_list" ]]; then
  echo "no orchestrator sessions — run: aid --mode orchestrator"
  exit 0
fi

_selected=$(printf '%s\n' "$_list" | fzf \
  --prompt="  session › " \
  --header="  enter:switch  ctrl-n:new  ctrl-d:delete  esc:close" \
  --no-sort \
  --ansi \
  --nth=1,2 \
  --delimiter='\t' \
  --with-nth=1 \
  --bind "ctrl-n:execute(printf '__new__')+abort" \
  --bind "ctrl-d:execute(printf '__del__%s' {+})+abort" \
  --color "header:italic:dim,prompt:blue,pointer:blue" \
  | grep -oE '\[(aid@[^]]+|__dead__aid@[^]]+|__new__|__del__[^\t]*)\]' \
  | tr -d '[]' || true)

case "${_selected:-}" in
  "")
    exit 0
    ;;
  __new__)
    exec "$AID_DIR/orchestrator.sh" --new
    ;;
  __del__*)
    # Extract the real session name from the tag (strip __del__ prefix).
    _target=$(printf '%s' "$_selected" | sed 's/^__del__//')
    # Strip __dead__ prefix if present (dead sessions also go through ctrl-d).
    _target=$(printf '%s' "$_target" | sed 's/^__dead__//')
    if [[ -n "$_target" ]]; then
      tmux -L aid kill-session -t "$_target" 2>/dev/null || true
      _meta_remove "$_target"
    fi
    # Reopen navigator after delete.
    exec "$AID_DIR/aid-sessions"
    ;;
  __dead__aid@*)
    # Resurrect: extract real session name and re-run orchestrator with saved repo.
    _real_session=$(printf '%s' "$_selected" | sed 's/^__dead__//')
    _repo=$(_meta_get "$_real_session" "repo_path")
    _project=$(printf '%s' "$_real_session" | cut -d'@' -f2 | cut -d'/' -f1)
    _slug=$(printf '%s' "$_real_session"    | cut -d'/' -f2)
    if [[ -d "${_repo:-}" ]]; then
      exec "$AID_DIR/orchestrator.sh" --resurrect "$_project" "$_slug" "$_repo"
    else
      echo "aid-sessions: repo path '$_repo' no longer exists for session $_real_session" >&2
      exit 1
    fi
    ;;
  aid@*)
    _switch "$_selected"
    ;;
esac
